SITE_DOMAIN=al-am.in
# Email used for Let's Encrypt registration (gets cert expiry notifications)
ACME_EMAIL=hire.credibly374@passinbox.com
# GHCR image reference that the VM pulls on each deploy
SITE_IMAGE=ghcr.io/OWNER/REPO:latest
